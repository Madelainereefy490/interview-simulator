# ══════════════════════════════════════════════
#  Interview Simulator Pro - AI Configuration
# ══════════════════════════════════════════════
# Pick ONE provider below. Set API key + model.

# ── Provider: anthropic | openai | google | groq | deepseek | openrouter ──
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ──
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── OpenAI (GPT-4o / o1) ──
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Google (Gemini) ──
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ── Groq (Llama / Mixtral - fast & free tier) ──
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── DeepSeek ──
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── OpenRouter (access ANY model with one key) ──
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5-20250929

# ── Server ──
PORT=3001
